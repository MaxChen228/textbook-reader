# Python
__pycache__/
*.py[cod]
.venv/

# Node（math_validate 的 render_check.js 依賴 mathjax-full；package.json/lock 追蹤、modules 不入 git）
book_pipeline/node_modules/

# macOS
.DS_Store

# 暫存 scratch（基線/驗證原型、實渲測試頁等）
tmp/

# 環境與憑證
.env
.env.local

# 靜態站產物（由 build 從 mineru_data 重生，不入 git）
/data/
/img/

# dev 監控快照（devctl snapshot 定時重生，不入 git；dev/index.html 才追蹤）
/dev/status.json
# per-book 抽屜詳情（timeline+sessions，60s devsnapshot 重生，可重生）
/dev/detail/
# 系統健康（errors/recent_log/corpus_sessions，devctl snapshot 重生，可重生）
/dev/system.json
# proposals 側欄 feed（devctl write_proposals 隨 snapshot 重生，可重生；proposals.d/ 才是真相）
/dev/proposals.json
# live 下載快訊（買書員逐本 下載中→✓/✗ 直寫，可重生）
/dev/crawl_live.json
# math sweep 可觀測性：即時串流快照 + 歷史批次回溯（math_sweep batch 直寫，可重生）
/dev/math_live.json
/dev/math_history.jsonl

# 教科書原始 PDF
raw_pdfs/
*.pdf

# resolver 誤配書的隔離區（re-home/quarantine 遷移搬入；保留 OCR 不刪、各機獨立、不入 git）
book_pipeline/_quarantine/

# Log 與 runtime 狀態
*.log
*.lock
book_pipeline/reports/
book_pipeline/.tick.lock
book_pipeline/_pending_batches.json
book_pipeline/mineru_budget.json
book_pipeline/pipeline_state.json
book_pipeline/.control/
book_pipeline/crawl_manifest.json
book_pipeline/crawl_resolution.json
book_pipeline/reload_request
book_pipeline/.controller.json

# mineru_data：git 只追蹤「貴重成果」(parsed/*.zh.json + extract_rules.yaml + cover.jpg)，
# 機器產物（unified 書頁圖+OCR、chunks/raw/batches、parsed/*.json）一律不入 git，改 rsync/Drive 備份。
book_pipeline/mineru_data/*/chunks/
book_pipeline/mineru_data/*/raw/
book_pipeline/mineru_data/*/batches/
book_pipeline/mineru_data/*/unified
book_pipeline/mineru_data/*/unified/
book_pipeline/mineru_data/*/_run.json
book_pipeline/mineru_data/*/_polls.jsonl
book_pipeline/mineru_data/*/_audit.md
book_pipeline/mineru_data/*/parsed/*.json
book_pipeline/mineru_data/*/parsed/_*.md
book_pipeline/mineru_data/*/parsed/_manual_repair_backups/
book_pipeline/mineru_data/*/parsed/_override_backups/
!book_pipeline/mineru_data/*/parsed/*.zh.json

# dev 即時工人面板（worker_registry 高頻寫，不入 git）
/dev/workers.json

# agent 歷史歸檔（agent_history append-only，standby 機器產物各機獨立，不入 git）
/dev/agent_history/

# 每書階段時間軸（觀測史，runtime，各機獨立，不入 git）
book_pipeline/book_timeline.json
book_pipeline/reports/crawl_plan.json
/dev/zlib_quota.json

# (book,stage) 租約（「此刻誰在跑」的 runtime 觀察，各機獨立，不入 git）
book_pipeline/.leases/
book_pipeline/.catalog_crit_cache.json
book_pipeline/.sol_stats_cache.json
book_pipeline/.scope_guard_seen.json
# storage_gc 冷藏目的地設定（各機獨立：HDD 掛載點不同；可重生）
book_pipeline/.storage_gc.json
book_pipeline/mineru_data/*/page*.png

# proposals 原子寫暫存（atomic_write_json 的 tmp 殘檔）
book_pipeline/proposals.d/*.tmp*

# triage 結果快取（按檔內容；可重生）＋ atomic_write 暫存（.triage_<rand>.json）
/book_pipeline/.triage_cache.json
/book_pipeline/.triage_*.json
# CPU 工具併發閘的 flock 槽（runtime，可重生）
/book_pipeline/.cpu_slots/
